# ──────────────────────────────────────────────────────────
# KubeCart Root Environment File
# Copy this to .env and fill in your real values before
# running docker compose up --build -d
# ──────────────────────────────────────────────────────────

# ─── JWT ───────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=CHANGE_THIS_to_a_64_char_random_hex_secret_at_minimum
JWT_REFRESH_SECRET=CHANGE_THIS_to_another_64_char_random_hex_secret

# Set this to your actual server IP or domain.
# Multiple origins: comma-separated, no spaces.
FRONTEND_URL=h'*'

# ─── SMTP (Email Notifications) ────────────────────────────
# See MANUAL_STEPS.md for Gmail App Password setup
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=ahamedaasik512@gmail.com
SMTP_PASS=kfmyrffrezkgwbiz
SMTP_FROM=KubeCart <ahamedaasik512@gmail.com>
