# Auth Service Environment Variables
PORT=4001
NODE_ENV=production
MONGO_URI=mongodb://auth-mongo:27017/auth_db
JWT_SECRET=change_this_to_a_strong_secret_min_32_characters
JWT_REFRESH_SECRET=change_this_to_another_strong_secret_min_32_characters
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
ALLOWED_ORIGINS=http://localhost:3000
FRONTEND_URL=http://localhost:3000
LOG_LEVEL=info
