# ─── Docker / Nginx (default) ───────────────────────────────────────────────
# Leave these empty so axios uses relative paths (e.g. /api/auth/login)
# Nginx reverse proxy forwards them to the correct backend service.
REACT_APP_AUTH_SERVICE_URL=
REACT_APP_PRODUCT_SERVICE_URL=
REACT_APP_ORDER_SERVICE_URL=
REACT_APP_CART_SERVICE_URL=
REACT_APP_PROFILE_SERVICE_URL=
REACT_APP_NOTIFICATION_SERVICE_URL=

# ─── Local Dev (no Docker) ───────────────────────────────────────────────────
# Uncomment these lines and comment out the empty ones above to talk
# directly to each service when running npm start locally:
# REACT_APP_AUTH_SERVICE_URL=http://localhost:4001
# REACT_APP_PRODUCT_SERVICE_URL=http://localhost:4002
# REACT_APP_ORDER_SERVICE_URL=http://localhost:4003
# REACT_APP_CART_SERVICE_URL=http://localhost:4004
# REACT_APP_PROFILE_SERVICE_URL=http://localhost:4005
# REACT_APP_NOTIFICATION_SERVICE_URL=http://localhost:4006

REACT_APP_APP_NAME=KubeCart
